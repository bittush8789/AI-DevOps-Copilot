# AWS Configuration
AWS_REGION=us-east-1

# Bedrock API Key (generate from AWS Console → Bedrock → API keys)
# https://docs.aws.amazon.com/bedrock/latest/userguide/api-keys.html
AWS_BEARER_TOKEN_BEDROCK=your_bedrock_api_key_here

# Alternative: IAM credentials (only if not using Bedrock API key)
# AWS_ACCESS_KEY_ID=your_access_key_here
# AWS_SECRET_ACCESS_KEY=your_secret_key_here

# Bedrock Configuration
BEDROCK_MODEL_ID=us.anthropic.claude-3-5-haiku-20241022-v1:0
BEDROCK_MAX_TOKENS=4096
BEDROCK_TEMPERATURE=0.7

# Vector Database (choose one)
VECTOR_DB_TYPE=opensearch  # or pinecone

# OpenSearch Configuration
OPENSEARCH_ENDPOINT=https://your-opensearch-endpoint.region.es.amazonaws.com
OPENSEARCH_USERNAME=admin
OPENSEARCH_PASSWORD=your_password_here
OPENSEARCH_INDEX=devops-knowledge

# Pinecone Configuration (alternative)
PINECONE_API_KEY=your_pinecone_api_key
PINECONE_ENVIRONMENT=us-east-1-aws
PINECONE_INDEX=devops-copilot

# CloudWatch Configuration
CLOUDWATCH_LOG_GROUP=/aws/eks/ai-devops-copilot

# Application Configuration
APP_PORT=8000
FRONTEND_PORT=3000
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Database (optional - for storing chat history)
DATABASE_URL=postgresql://user:password@localhost:5432/devops_copilot

# Redis (optional - for caching)
REDIS_URL=redis://localhost:6379/0
